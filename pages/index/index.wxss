.page {
  padding: 24rpx;
}

.title {
  margin-bottom: 16rpx;
  font-weight: 600;
}

.preview {
  width: 100%;
  height: 420rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #eef2ff;
}

.size-list {
  display: flex;
  gap: 16rpx;
}

.size-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
}

.size-chip--active {
  background: #2563eb;
  color: #ffffff;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}
